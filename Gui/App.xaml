<Application
    x:Class="Winstaller.Gui.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WinstallerPageBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="WinstallerPaneBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="WinstallerTitleBarBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="WinstallerCardBrush" Color="#2B2B2B" />
                    <SolidColorBrush x:Key="WinstallerCardStrokeBrush" Color="#44FFFFFF" />
                    <SolidColorBrush x:Key="WinstallerModuleCardHoverBrush" Color="#393939" />
                    <SolidColorBrush x:Key="WinstallerSecondaryTextBrush" Color="#C5C5C5" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="WinstallerPageBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="WinstallerPaneBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="WinstallerTitleBarBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="WinstallerCardBrush" Color="#FBFBFB" />
                    <SolidColorBrush x:Key="WinstallerCardStrokeBrush" Color="#22000000" />
                    <SolidColorBrush x:Key="WinstallerModuleCardHoverBrush" Color="#F0F6FF" />
                    <SolidColorBrush x:Key="WinstallerSecondaryTextBrush" Color="#5D5D5D" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="WinstallerPageBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="WinstallerPaneBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="WinstallerTitleBarBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="WinstallerCardBrush" Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="WinstallerCardStrokeBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                    <SolidColorBrush x:Key="WinstallerModuleCardHoverBrush" Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="WinstallerSecondaryTextBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
